{
  "info": {
    "name": "Sistema de Citas Medicas - API",
    "description": "Coleccion de peticiones para probar la API REST del sistema de citas medicas (auth con JWT + CRUD de citas).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:5000/api" },
    { "key": "token", "value": "" },
    { "key": "medico_id", "value": "" },
    { "key": "cita_id", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Registrar paciente",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/auth/registro",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Carlos Ramirez\",\n  \"email\": \"carlos@correo.com\",\n  \"password\": \"paciente123\",\n  \"rol\": \"paciente\",\n  \"telefono\": \"0991234567\"\n}"
            }
          }
        },
        {
          "name": "Registrar medico",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/auth/registro",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Dra. Ana Torres\",\n  \"email\": \"ana.torres@clinica.com\",\n  \"password\": \"medico123\",\n  \"rol\": \"medico\",\n  \"especialidad\": \"Cardiologia\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const data = pm.response.json();",
                  "if (data.token) { pm.collectionVariables.set('token', data.token); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"carlos@correo.com\",\n  \"password\": \"paciente123\"\n}"
            }
          }
        },
        {
          "name": "Perfil (ruta protegida)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/auth/perfil"
          }
        },
        {
          "name": "Listar medicos",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Script eliminado para que la elección del médico sea manual"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/auth/medicos"
          }
        },
        {
          "name": "Listar pacientes",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/auth/pacientes"
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/auth/logout"
          }
        }
      ]
    },
    {
      "name": "Citas (CRUD)",
      "item": [
        {
          "name": "Crear cita",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const data = pm.response.json();",
                  "if (data.cita) { pm.collectionVariables.set('cita_id', data.cita._id); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/citas",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"paciente\": \"\",\n  \"medico\": \"\",\n  \"especialidad\": \"Cardiologia\",\n  \"fecha\": \"2026-07-20\",\n  \"hora\": \"09:30\",\n  \"motivo\": \"Control anual de presion arterial\"\n}"
            }
          }
        },
        {
          "name": "Listar citas",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/citas"
          }
        },
        {
          "name": "Obtener cita por ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/citas/{{cita_id}}"
          }
        },
        {
          "name": "Actualizar cita (cambiar estado)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/citas/{{cita_id}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"estado\": \"confirmada\"\n}"
            }
          }
        },
        {
          "name": "Eliminar cita",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/citas/{{cita_id}}"
          }
        }
      ]
    }
  ]
}